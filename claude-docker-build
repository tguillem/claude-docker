#!/bin/bash
# Build (or rebuild) the claude-docker image
#   Default:  update Claude only (fast, reuses cached OS layers)
#   --full:   rebuild everything including Debian packages

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
USER_ARG="--build-arg USER=$(whoami)"

if [[ "$1" == "--full" ]]; then
  docker build --no-cache $USER_ARG -t claude-docker "$SCRIPT_DIR"
else
  docker build --build-arg CLAUDE_VERSION="$(date +%s)" $USER_ARG -t claude-docker "$SCRIPT_DIR"
fi
